# NetMap configuration
# ─────────────────────────────────────────────────────────────────────────────
# The production docker-compose.yml defines these values directly in its
# environment block. This file is kept as a variable reference and for
# maintainers using docker-compose.build.yml with --env-file or a local .env.
#
# Generate SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Generate MASTER_KEY (Fernet):
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Keep both stable across restarts — changing SECRET_KEY invalidates all active
# sessions, and changing MASTER_KEY makes encrypted stored secrets unreadable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required secrets ─────────────────────────────────────────────────────────
SECRET_KEY=replace-with-output-of-python-secrets-token-urlsafe
MASTER_KEY=replace-with-output-of-fernet-generate-key

# ── Network / CORS ───────────────────────────────────────────────────────────
# Set these to the exact origin and hostname your browser connects from.
CORS_ORIGINS=["https://netmap.example.com"]
TRUSTED_HOSTS=["netmap.example.com"]

# ── HTTPS / Security headers ─────────────────────────────────────────────────
# Set to true when the container sits behind a TLS-terminating reverse proxy.
SECURE_HSTS_ENABLED=false

# Set to true to mark auth cookies as Secure (requires HTTPS).
AUTH_COOKIE_SECURE=false

# ── Reverse proxy ────────────────────────────────────────────────────────────
# IPs or CIDR ranges of your reverse proxy (so forwarded headers are trusted).
# TRUSTED_PROXY_IPS=["127.0.0.1","192.168.1.0/24"]

# ── Logging ──────────────────────────────────────────────────────────────────
# debug | info | warning | error | critical
LOG_LEVEL=info

# ── Data retention ───────────────────────────────────────────────────────────
EVENT_RETENTION_DAYS=7
FIREWALL_LOG_RETENTION_DAYS=7

# ── Syslog receiver ──────────────────────────────────────────────────────────
SYSLOG_ENABLED=true
SYSLOG_UDP_ENABLED=true
SYSLOG_TCP_ENABLED=true
SYSLOG_UDP_PORT=1514
SYSLOG_TCP_PORT=1514

# Restrict which sender IPs are accepted (leave unset to accept all).
# SYSLOG_SENDER_ALLOWLIST=["192.168.1.1","10.0.0.0/8"]

# Active ping/traceroute/TCP tools only allow private, loopback, and link-local
# targets by default. This sets the initial default; SuperAdmins can later
# change it in Admin -> System.
# ACTIVE_NETWORK_PUBLIC_TARGETS_ENABLED=false

# ── Application URL ───────────────────────────────────────────────────────────
# Set to the public URL users visit so password-reset links in emails are correct.
# Without this, links are built from the server's internal base URL which may be
# wrong when behind a reverse proxy.
# APP_URL=http://netmap.example.com:8080

# ── Authentication ────────────────────────────────────────────────────────────
# ACCESS_TOKEN_MINUTES=15
# IDLE_TIMEOUT_MINUTES=15
# REFRESH_TOKEN_DAYS=7
# AUTH_MAX_FAILED_ATTEMPTS=5
# AUTH_LOCKOUT_MINUTES=15
